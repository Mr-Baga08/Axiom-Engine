# axiom-engine environment variables
# Copy this file to .env and fill in the values marked REQUIRED.
#
# Generate random secrets:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Gemini API key — used by the agent and RAGAS evaluation.
# Free tier: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# JWT signing secret (HS256). Generate one with the command above.
JWT_SECRET=

# HMAC-SHA256 key for document chunk tamper detection. Generate separately.
HMAC_SECRET=
CHUNK_HMAC_SECRET=

# ── LLM PROVIDER ──────────────────────────────────────────────────────────────

# Switch the entire agent between providers: gemini (default) | anthropic
LLM_PROVIDER=gemini

# Gemini model for the agent loop.
# gemini-2.5-flash-lite  — fast, cheap (default)
# gemini-2.5-flash       — more capable
# gemini-2.5-pro         — most capable
GEMINI_AGENT_MODEL=gemini-2.5-flash-lite

# Gemini model used only for RAGAS evaluation scoring (separate from agent).
GEMINI_EVAL_MODEL=gemini-2.5-flash

# Anthropic key — required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── DATABASE ──────────────────────────────────────────────────────────────────

# duckdb  — local file, no setup required (default for development)
# postgres — full PostgreSQL with pgvector (recommended for production)
DB_BACKEND=duckdb

DUCKDB_PATH=data/duckdb/analytics.duckdb

# Used only when DB_BACKEND=postgres
POSTGRES_DSN=postgresql://axiom_admin:dev_password@postgres:5432/axiom_db
POSTGRES_USER=axiom_admin
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=axiom_db

# ── REDIS ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0

# ── FRONTEND ──────────────────────────────────────────────────────────────────

# URL the Next.js server-side routes use to reach the Python API.
# Docker: use the service name. Local: use localhost.
BACKEND_URL=http://api-python:8000

# URL the Next.js server uses to reach the Go SSE gateway.
GO_SSE_URL=http://api-go:8080

# Comma-separated CORS origins allowed by the Python API.
CORS_ORIGINS=http://localhost:3000

# ── GO SSE GATEWAY ────────────────────────────────────────────────────────────

AI_SERVICE_URL=http://api-python:8000
PORT=8080
RATE_LIMIT_RPM=10
CB_THRESHOLD=3
CB_WINDOW_SECONDS=30
CB_OPEN_SECONDS=60

# ── OPTIONAL: LangFuse tracing ────────────────────────────────────────────────
# Leave blank to disable — all observability calls degrade gracefully.
# https://langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── OPTIONAL: RAGAS watchdog ──────────────────────────────────────────────────
# Slack webhook for alerts when context_relevance drops below threshold.
SLACK_WEBHOOK_URL=
RAGAS_ALERT_THRESHOLD=0.7
RAGAS_POLL_INTERVAL_SECONDS=600

# ── OPTIONAL: HashiCorp Vault ─────────────────────────────────────────────────
# If set, the Python API loads secrets from Vault at startup.
# Leave blank to use .env directly.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/ai-insights

# ── OPTIONAL: DSPy ───────────────────────────────────────────────────────────
EXAMPLES_PATH=data/dspy_examples.json
DSPY_OUTPUT_PATH=data/dspy_compiled.json

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
